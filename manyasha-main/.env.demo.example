# Manaya profile: demo (стабильный показ)
APP_ENV=demo

# Infra
DATABASE_URL=sqlite:///./backend-local.db
REDIS_URL=redis://localhost:6379/0
MANAYA_USE_CREATE_ALL=1

# Security (demo placeholders)
JWT_SECRET=demo_jwt_secret_change_me
ENCRYPTION_KEY=demo_encryption_key_32_bytes_change
WIDGET_AUTH_SECRET=

# Widget context/install (можно ослабить для демо-стенда)
WIDGET_CONTEXT_REQUIRE_INSTALL=false
WIDGET_INSTALL_SIGNING_SECRET=
WIDGET_INSTALL_PROVISION_KEY=
WIDGET_INSTALL_TOKEN_TTL_SECONDS=900
MANYASHA_EMBED_CONTRACT_VERSION=1
MANYASHA_EMBED_SUPPORTED_CONTRACT_VERSIONS=1

# CORS для демо-стенда
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:4173,http://127.0.0.1:4173
CORS_ALLOW_NULL_ORIGIN=true

# Manyasha LLM (быстрый бюджет)
MANYASHA_LLM_PROVIDER=navy
NAVY_API_BASE_URL=https://api.navy/v1
NAVY_MODEL=gpt-5
NAVY_API_KEY=your_key_here
MANYASHA_DEMO_FAST_MODE=true
MANYASHA_CHAT_LLM_TIMEOUT_SECONDS=4.2

# Fallback providers
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Voice
MANYASHA_TTS_PROVIDER=auto
MANYASHA_CHAT_CACHE_VERSION=v3

# Важно: demo_mode включается только query-параметром URL, не env-переменной.
