# Manaya profile: prod (безопасный production)
APP_ENV=production

# Infra (prod)
DATABASE_URL=postgresql://manaya_user:change_me@postgres:5432/manaya
REDIS_URL=redis://redis:6379/0
MANAYA_USE_CREATE_ALL=0

# Mandatory security secrets
JWT_SECRET=change_me_prod_jwt_secret
ENCRYPTION_KEY=change_me_prod_encryption_key_32_bytes
WIDGET_AUTH_SECRET=change_me_prod_widget_auth_secret
WIDGET_INSTALL_SIGNING_SECRET=change_me_prod_install_signing_secret
WIDGET_INSTALL_PROVISION_KEY=change_me_prod_install_provision_secret
WIDGET_INSTALL_TOKEN_TTL_SECONDS=900

# Widget protection (strict)
WIDGET_CONTEXT_REQUIRE_INSTALL=true
MANYASHA_EMBED_CONTRACT_VERSION=1
MANYASHA_EMBED_SUPPORTED_CONTRACT_VERSIONS=1

# CORS (strict allowlist only)
CORS_ALLOW_ORIGINS=https://your-main-domain.ru,https://widget.your-main-domain.ru
CORS_ALLOW_NULL_ORIGIN=false

# Manyasha LLM
MANYASHA_LLM_PROVIDER=navy
NAVY_API_BASE_URL=https://api.navy/v1
NAVY_MODEL=gpt-5
NAVY_API_KEY=your_key_here
MANYASHA_DEMO_FAST_MODE=false
MANYASHA_CHAT_LLM_TIMEOUT_SECONDS=12.0

# Fallback providers
OLLAMA_URL=http://ollama-internal:11434
OLLAMA_MODEL=qwen2.5:7b
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Voice
MANYASHA_TTS_PROVIDER=auto
MANYASHA_CHAT_CACHE_VERSION=v3

# Demo mode по умолчанию в production не включается.
