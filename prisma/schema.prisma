generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums: нормализация статусов/ролей до целостности на уровне БД ──
// Значения совпадают с тем, что уже пишет код (иначе сломались бы вставки).
enum LeadStatus {
  new
  contacted
  qualified
  paid
  rejected
  lost
}

enum UserRole {
  user
  admin
}

enum BroadcastStatus {
  pending
  sending
  sent
  failed
}

enum RecipientStatus {
  pending
  sent
  failed
  skipped
}

enum LoginOutcome {
  ok
  fail
}

// Справочник тарифов как enum (реальные ступени БФЛ).
enum TariffTier {
  start
  praktik
  vnedrenie
}

enum OrderStatus {
  pending
  paid
  cancelled
  refunded
}

enum ConsentType {
  pdn
  marketing
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  phone     String   @db.VarChar(20)
  // Только цифры — устойчивый ключ дедупликации и связки lead↔user по телефону.
  // Заполняется на записи; индекс даёт быстрый поиск дублей без выборки «последних 200».
  phoneNormalized String? @map("phone_normalized") @db.VarChar(20)
  email     String?  @db.VarChar(200)
  // Свободная строка: интерес лида (включает не-тарифы вроде «Lead Magnet»).
  tariff    String   @db.VarChar(50)
  comment   String?  @db.VarChar(1000)
  status    LeadStatus @default(new)
  source    String?  @db.VarChar(40)
  userId    Int?     @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Доказуемость согласия на обработку ПДн (ч.1 ст.9 152-ФЗ): бремя доказывания
  // на операторе — фиксируем факт, время, IP и версию документов.
  consent          Boolean   @default(false)
  marketingConsent Boolean   @default(false) @map("marketing_consent")
  consentAt        DateTime? @map("consent_at")
  consentIp        String?   @map("consent_ip") @db.VarChar(64)
  policyVersion    String?   @map("policy_version") @db.VarChar(20)
  // Ретеншн и отзыв согласия (ст.5 п.7 — ограничение срока хранения; ст.21 152-ФЗ).
  // purgeAfter — момент, после которого лид подлежит удалению/обезличиванию джобой;
  // revokedAt — факт отзыва согласия субъектом (обработка прекращается по иным основаниям).
  purgeAfter       DateTime? @map("purge_after")
  revokedAt        DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  consents  ConsentRecord[]

  @@index([userId])
  @@index([phoneNormalized])
  @@index([status])
  @@map("leads")
}

// Registered users — can sign in via email/password and/or Telegram.
model User {
  id               Int       @id @default(autoincrement())
  email            String?   @unique @db.VarChar(200)
  passwordHash     String?   @map("password_hash") @db.VarChar(255)
  name             String    @db.VarChar(100)
  phone            String?   @db.VarChar(20)
  telegramId       String?   @unique @map("telegram_id") @db.VarChar(32)
  telegramUsername String?   @map("telegram_username") @db.VarChar(64)
  tariff           String?   @db.VarChar(50)
  role             UserRole  @default(user)
  // Согласие на обработку ПДн, зафиксированное при регистрации.
  consentAt        DateTime? @map("consent_at")
  consentVersion   String?   @map("consent_version") @db.VarChar(20)
  marketingConsent Boolean   @default(false) @map("marketing_consent")
  // Последняя активность пользователя в боте (аудитория Telegram живёт в User, а
  // не в bot/data/users.json). Питает /stats («активны сегодня») и импорт из users.json.
  lastSeenAt       DateTime? @map("last_seen_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  sessions         Session[]
  leads            Lead[]
  orders           Order[]
  consents         ConsentRecord[]

  @@map("users")
}

// Server-side sessions. The opaque token id lives in an httpOnly cookie.
model Session {
  id        String   @id @db.VarChar(64)
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("sessions")
}

// One-time codes for the "Login via Telegram" deep-link flow.
model AuthCode {
  code             String    @id @db.VarChar(48)
  telegramId       String?   @map("telegram_id") @db.VarChar(32)
  telegramUsername String?   @map("telegram_username") @db.VarChar(64)
  firstName        String?   @map("first_name") @db.VarChar(100)
  // Привязка кода к браузеру-инициатору /start (owner-token лежит и в httpOnly-cookie);
  // /status минтит сессию только при совпадении → закрыт session-fixation / ATO.
  ownerToken       String?   @map("owner_token") @db.VarChar(64)
  confirmedAt      DateTime? @map("confirmed_at")
  consumedAt       DateTime? @map("consumed_at")
  expiresAt        DateTime  @map("expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  // Дешёвый deleteMany истёкших/использованных кодов в ретеншн-джобе (C8).
  @@index([expiresAt])
  @@index([consumedAt])
  @@map("auth_codes")
}

// Broadcast queue: web admin enqueues, the bot polls + delivers to all users.
model Broadcast {
  id          Int             @id @default(autoincrement())
  message     String          @db.VarChar(4000)
  status      BroadcastStatus @default(pending)
  sentCount   Int             @default(0) @map("sent_count")
  failedCount Int             @default(0) @map("failed_count")
  createdAt   DateTime        @default(now()) @map("created_at")
  sentAt      DateTime?       @map("sent_at")

  // Пер-получательный лог доставки (C7, ст.18 149-ФЗ): доказуемость того, что
  // рассылка ушла только давшим маркетинговое согласие и исключила отозвавших.
  recipients  BroadcastRecipient[]

  @@index([status])
  @@map("broadcasts")
}

// Лог получателей маркетинговой рассылки (C7 / D1, ст.18 149-ФЗ).
// Фиксирует, кому и с каким статусом ушло сообщение — бремя доказывания
// правомерности рекламной рассылки на операторе. telegramId — для аудитории бота
// (users.json), userId — для веб-канала; заполняется тот, что известен на момент отправки.
model BroadcastRecipient {
  id          Int             @id @default(autoincrement())
  broadcastId Int             @map("broadcast_id")
  broadcast   Broadcast       @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  telegramId  String?         @map("telegram_id") @db.VarChar(32)
  userId      Int?            @map("user_id")
  status      RecipientStatus
  deliveredAt DateTime?       @map("delivered_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([broadcastId])
  @@map("broadcast_recipients")
}

// Журнал попыток входа как контроль ИБ (152-ФЗ, ст.19 — учёт действий с ПДн).
// Раньше события жили только в PM2-логах: неконтролируемый из схемы срок хранения,
// невозможно предъявить аудит-трейл по запросу. Теперь — модель с TTL через
// ретеншн-джобу. ПДн минимизированы: e-mail только псевдонимным хешем, IP — усечённый.
model LoginEvent {
  id        Int          @id @default(autoincrement())
  userId    Int?         @map("user_id")
  emailHash String?      @map("email_hash") @db.VarChar(16)
  ip        String?      @db.VarChar(64)
  outcome   LoginOutcome
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("login_events")
}

// Покупка тарифа. Отдельная модель под факт оплаты (раньше нигде не фиксировалась):
// связь с пользователем, ступень тарифа (enum), сумма, статус и момент оплаты.
model Order {
  id        Int         @id @default(autoincrement())
  userId    Int         @map("user_id")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tariff    TariffTier
  amount    Int
  status    OrderStatus @default(pending)
  paidAt    DateTime?   @map("paid_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("orders")
}

// Единый реестр согласий (DRY + аудит): раньше consent*-поля дублировались в Lead и User.
// Каждая запись — факт выдачи/отзыва согласия конкретного типа, с версией документа и IP.
model ConsentRecord {
  id        Int         @id @default(autoincrement())
  userId    Int?        @map("user_id")
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  leadId    Int?        @map("lead_id")
  lead      Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  type      ConsentType
  granted   Boolean     @default(true)
  version   String?     @db.VarChar(20)
  ip        String?     @db.VarChar(64)
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([leadId])
  @@map("consent_records")
}
